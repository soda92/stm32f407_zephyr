# Use the working built-in Discovery script as a base
include @scripts/single-node/stm32f4_discovery.resc

# Load additional peripherals from REPL file
machine LoadPlatformDescription @my_port/extra_peripherals.repl

# Load your application
sysbus LoadELF @build/zephyr/zephyr.elf

# Load Python mock handlers
#python -u @my_port/peripherals.py

# Redirect UART1 output to the terminal (useful for CLI mode)
sysbus.usart1 CreateFileBackend "/dev/stdout"

# Start the simulation
start
